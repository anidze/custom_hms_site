generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model booking_status {
  id         Int        @id(map: "PK__booking___3213E83F10D7B4E2") @default(autoincrement())
  code       String     @unique(map: "UQ__booking___357D4CF93749099F") @db.NVarChar(50)
  name_geo   String     @db.NVarChar(100)
  name_eng   String     @db.NVarChar(100)
  color_hex  String?    @db.NChar(7)
  sort_order Int        @default(0, map: "DF__booking_s__sort___4AB81AF0") @db.TinyInt
  is_active  Boolean    @default(true, map: "DF__booking_s__is_ac__4BAC3F29")
  created_at DateTime   @default(now(), map: "DF__booking_s__creat__4CA06362")
  bookings   bookings[]
}

model bookings {
  id             Int            @id(map: "PK__bookings__3213E83F8BCDDF85") @default(autoincrement())
  hotel_id       Int
  room_id        Int
  guest_id       Int
  status_id      Int
  created_by     Int
  check_in       DateTime       @db.Date
  check_out      DateTime       @db.Date
  nights         Int?
  guests_count   Int            @default(1, map: "DF__bookings__guests__73BA3083") @db.TinyInt
  total_price    Decimal        @db.Decimal(10, 2)
  notes          String?        @db.NVarChar(2000)
  cancelled_at   DateTime?
  cancel_reason  String?        @db.NVarChar(500)
  created_at     DateTime       @default(now(), map: "DF__bookings__create__74AE54BC")
  updated_at     DateTime       @default(now(), map: "DF__bookings__update__75A278F5")
  users          users          @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "FK__bookings__create__72C60C4A")
  guests         guests         @relation(fields: [guest_id], references: [id], onUpdate: NoAction, map: "FK__bookings__guest___70DDC3D8")
  hotels         hotels         @relation(fields: [hotel_id], references: [id], onUpdate: NoAction, map: "FK__bookings__hotel___6EF57B66")
  rooms          rooms          @relation(fields: [room_id], references: [id], onUpdate: NoAction, map: "FK__bookings__room_i__6FE99F9F")
  booking_status booking_status @relation(fields: [status_id], references: [id], onUpdate: NoAction, map: "FK__bookings__status__71D1E811")
  payments       payments[]

  @@index([check_in, check_out], map: "IX_bookings_checkin")
  @@index([guest_id], map: "IX_bookings_guest_id")
  @@index([hotel_id], map: "IX_bookings_hotel_id")
  @@index([room_id], map: "IX_bookings_room_id")
  @@index([status_id], map: "IX_bookings_status")
}

model guests {
  id          Int        @id(map: "PK__guests__3213E83F051A28F7") @default(autoincrement())
  hotel_id    Int
  full_name   String     @db.NVarChar(200)
  id_number   String?    @db.NVarChar(50)
  phone       String?    @db.NVarChar(50)
  email       String?    @db.NVarChar(200)
  nationality String?    @db.NVarChar(100)
  notes       String?    @db.NVarChar(2000)
  created_at  DateTime   @default(now(), map: "DF__guests__created___6B24EA82")
  updated_at  DateTime   @default(now(), map: "DF__guests__updated___6C190EBB")
  bookings    bookings[]
  hotels      hotels     @relation(fields: [hotel_id], references: [id], onUpdate: NoAction, map: "FK__guests__hotel_id__6A30C649")

  @@index([hotel_id], map: "IX_guests_hotel_id")
}

model hotel_category {
  id         Int      @id(map: "PK__hotel_ca__3213E83F4967F542") @default(autoincrement())
  code       String   @unique(map: "UQ__hotel_ca__357D4CF9C721C839") @db.NVarChar(50)
  name_geo   String   @db.NVarChar(100)
  name_eng   String   @db.NVarChar(100)
  stars      Int?     @db.TinyInt
  sort_order Int      @default(0, map: "DF__hotel_cat__sort___398D8EEE") @db.TinyInt
  is_active  Boolean  @default(true, map: "DF__hotel_cat__is_ac__3A81B327")
  created_at DateTime @default(now(), map: "DF__hotel_cat__creat__3B75D760")
  hotels     hotels[]
}

model hotels {
  id             Int            @id(map: "PK__hotels__3213E83FDEABCDF2") @default(autoincrement())
  category_id    Int
  name           String         @db.NVarChar(200)
  legal_name     String?        @db.NVarChar(200)
  address        String         @db.NVarChar(500)
  city           String         @default("N'თბილისი'", map: "DF__hotels__city__5535A963") @db.NVarChar(100)
  phone          String?        @db.NVarChar(50)
  email          String?        @db.NVarChar(200)
  website        String?        @db.NVarChar(300)
  tax_id         String?        @db.NVarChar(50)
  is_active      Boolean        @default(true, map: "DF__hotels__is_activ__5629CD9C")
  created_at     DateTime       @default(now(), map: "DF__hotels__created___571DF1D5")
  updated_at     DateTime       @default(now(), map: "DF__hotels__updated___5812160E")
  logoUrl        String?        @db.NVarChar(500)
  bookings       bookings[]
  guests         guests[]
  hotel_category hotel_category @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "FK__hotels__category__5441852A")
  rooms          rooms[]
  users          users[]
}

model payment_method {
  id         Int        @id(map: "PK__payment___3213E83F27DECCE7") @default(autoincrement())
  code       String     @unique(map: "UQ__payment___357D4CF9AF0FECE0") @db.NVarChar(50)
  name_geo   String     @db.NVarChar(100)
  name_eng   String     @db.NVarChar(100)
  is_active  Boolean    @default(true, map: "DF__payment_m__is_ac__5070F446")
  created_at DateTime   @default(now(), map: "DF__payment_m__creat__5165187F")
  payments   payments[]
}

model payments {
  id             Int            @id(map: "PK__payments__3213E83F827E4278") @default(autoincrement())
  booking_id     Int
  method_id      Int
  amount         Decimal        @db.Decimal(10, 2)
  currency       String         @default("GEL", map: "DF__payments__curren__7B5B524B") @db.NChar(3)
  reference      String?        @db.NVarChar(200)
  notes          String?        @db.NVarChar(500)
  created_by     Int
  paid_at        DateTime       @default(now(), map: "DF__payments__paid_a__7D439ABD")
  bookings       bookings       @relation(fields: [booking_id], references: [id], onUpdate: NoAction, map: "FK__payments__bookin__797309D9")
  users          users          @relation(fields: [created_by], references: [id], onUpdate: NoAction, map: "FK__payments__create__7C4F7684")
  payment_method payment_method @relation(fields: [method_id], references: [id], onUpdate: NoAction, map: "FK__payments__method__7A672E12")

  @@index([booking_id], map: "IX_payments_booking")
}

model room_type {
  id          Int      @id(map: "PK__room_typ__3213E83FED9A29E4") @default(autoincrement())
  code        String   @unique(map: "UQ__room_typ__357D4CF9ADCA7946") @db.NVarChar(50)
  name_geo    String   @db.NVarChar(100)
  name_eng    String   @db.NVarChar(100)
  description String?  @db.NVarChar(500)
  sort_order  Int      @default(0, map: "DF__room_type__sort___44FF419A") @db.TinyInt
  is_active   Boolean  @default(true, map: "DF__room_type__is_ac__45F365D3")
  created_at  DateTime @default(now(), map: "DF__room_type__creat__46E78A0C")
  rooms       rooms[]
}

model rooms {
  id              Int        @id(map: "PK__rooms__3213E83F408B7018") @default(autoincrement())
  hotel_id        Int
  room_type_id    Int
  room_number     String     @db.NVarChar(20)
  floor           Int?       @db.TinyInt
  price_per_night Decimal    @db.Decimal(10, 2)
  max_guests      Int        @default(2, map: "DF__rooms__max_guest__656C112C") @db.TinyInt
  description     String?
  is_available    Boolean    @default(true, map: "DF__rooms__is_availa__66603565")
  created_at      DateTime   @default(now(), map: "DF__rooms__created_a__6754599E")
  bookings        bookings[]
  hotels          hotels     @relation(fields: [hotel_id], references: [id], onUpdate: NoAction, map: "FK__rooms__hotel_id__6383C8BA")
  room_type       room_type  @relation(fields: [room_type_id], references: [id], onUpdate: NoAction, map: "FK__rooms__room_type__6477ECF3")

  @@unique([hotel_id, room_number], map: "UQ_rooms_hotel_number")
  @@index([hotel_id], map: "IX_rooms_hotel_id")
  @@index([room_type_id], map: "IX_rooms_type_id")
}

model user_role {
  id          Int      @id(map: "PK__user_rol__3213E83FC04F5DC5") @default(autoincrement())
  code        String   @unique(map: "UQ__user_rol__357D4CF9B2B6E8AC") @db.NVarChar(50)
  name_geo    String   @db.NVarChar(100)
  name_eng    String   @db.NVarChar(100)
  description String?  @db.NVarChar(500)
  sort_order  Int      @default(0, map: "DF__user_role__sort___3F466844") @db.TinyInt
  is_active   Boolean  @default(true, map: "DF__user_role__is_ac__403A8C7D")
  created_at  DateTime @default(now(), map: "DF__user_role__creat__412EB0B6")
  users       users[]
}

model users {
  id            Int        @id(map: "PK__users__3213E83F3D9F9F44") @default(autoincrement())
  role_id       Int
  hotel_id      Int?
  full_name     String     @db.NVarChar(200)
  email         String     @unique(map: "UQ__users__AB6E61647B059697") @db.NVarChar(200)
  password_hash String     @db.NVarChar(500)
  phone         String?    @db.NVarChar(50)
  is_active     Boolean    @default(true, map: "DF__users__is_active__5DCAEF64")
  last_login_at DateTime?
  created_at    DateTime   @default(now(), map: "DF__users__created_a__5EBF139D")
  updated_at    DateTime   @default(now(), map: "DF__users__updated_a__5FB337D6")
  bookings      bookings[]
  payments      payments[]
  hotels        hotels?    @relation(fields: [hotel_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK__users__hotel_id__5CD6CB2B")
  user_role     user_role  @relation(fields: [role_id], references: [id], onUpdate: NoAction, map: "FK__users__role_id__5BE2A6F2")

  @@index([hotel_id], map: "IX_users_hotel_id")
  @@index([role_id], map: "IX_users_role_id")
}
